# Copy to .env and fill from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Spring Boot API — required on Vercel (browser calls Railway directly; no /api proxy there)
# Production (match vite.config.js proxy target): https://el-kapitan-production.up.railway.app
# VITE_API_BASE_URL=https://el-kapitan-production.up.railway.app
# Local: use Vite proxy and set VITE_API_BASE_URL=/api, or point at http://localhost:8080
